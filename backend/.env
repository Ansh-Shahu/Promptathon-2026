# backend/.env

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hvac_telemetry.db

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME="HVAC Predictive Maintenance API"

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:8000", "http://localhost:5173", "http://localhost:5174", "http://localhost:5175"]

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-secret-before-deploying

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── ML Model ──────────────────────────────────────────────────────────────────
MODEL_PATH=./model.pkl